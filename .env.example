# Application environment
# "development" disables certain production-only guards (e.g. strict CORS)
ENVIRONMENT=development

# Firebase / Google Cloud
# The Firebase project ID for this application
GOOGLE_CLOUD_PROJECT=rscommendation-493408

# Application Default Credentials (ADC) path
# =============================================
# Docker Compose uses this variable to mount your GCP credentials into the container.
# Set the appropriate path based on your operating system:

# === Windows ===
# gcloud stores ADC at: %APPDATA%\gcloud\application_default_credentials.json
# Which expands to: C:\Users\<YourUsername>\AppData\Roaming\gcloud\application_default_credentials.json
GOOGLE_APPLICATION_CREDENTIALS=C:\Users\Rein\AppData\Roaming\gcloud\application_default_credentials.json

# === macOS ===
# gcloud stores ADC at: ~/.config/gcloud/application_default_credentials.json
# GOOGLE_APPLICATION_CREDENTIALS=$HOME/.config/gcloud/application_default_credentials.json

# === Linux ===
# gcloud stores ADC at: ~/.config/gcloud/application_default_credentials.json
# GOOGLE_APPLICATION_CREDENTIALS=$HOME/.config/gcloud/application_default_credentials.json

# To generate ADC credentials, run:
#   gcloud auth application-default login
# This will create and populate the credentials file automatically.
